{
  "name": "ulakssh",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "author": "Osman Beyhan <osman@beyhan.com>",
  "description": "Modern SSH and SFTP management client.",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm:electron\"",
    "electron": "wait-on http://localhost:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:electron": "tsc electron/main.ts electron/preload.cts --outDir dist-electron --target ES2022 --module NodeNext --moduleResolution NodeNext",
    "build:frontend": "vite build",
    "build": "npm run build:frontend && npm run build:electron && electron-builder --linux --windows",
    "build:linux": "npm run build:frontend && npm run build:electron && electron-builder --linux",
    "build:win": "npm run build:frontend && npm run build:electron && electron-builder --windows",
    "build:mac": "npm run build:frontend && npm run build:electron && electron-builder --macos",
    "build:all": "npm run build:frontend && npm run build:electron && electron-builder --linux --windows --macos"
  },
  "build": {
    "appId": "com.osmn-byhn.ulakssh",
    "productName": "ulakSSH",
    "executableName": "ulakssh",
    "directories": {
      "output": "release/1.0.0"
    },
    "files": [
      "dist-electron",
      "dist",
      "index.html"
    ],
    "linux": {
      "maintainer": "Osman Beyhan <developer@osmanbeyhan.com>",
      "icon": "public/logo.png",
      "target": [
        "rpm",
        "deb",
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "icon": "public/logo.png"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@osmn-byhn/changelog-github-core": "^1.1.0",
    "@osmn-byhn/changelog-github-updater": "^1.0.3",
    "@types/ssh2": "^1.15.5",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9.2.1",
    "ssh2": "^1.17.0",
    "default-shell": "^2.2.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "wait-on": "^9.0.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-file-tree": "^0.0.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "monaco-editor": "^0.52.2",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "react-is": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}